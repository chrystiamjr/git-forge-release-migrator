{
  "name": "git-forge-release-migrator",
  "private": true,
  "description": "Release automation tooling for git-forge-release-migrator",
  "scripts": {
    "cm": "git cz",
    "fvm:global": "node scripts/fvm-global.js",
    "get:dart": "fvm dart pub get",
    "get:flutter": "fvm flutter pub get",
    "prepare": "husky",
    "lint:dart": "cd dart_cli && node ../scripts/run-dart.js format -l 120 --set-exit-if-changed bin lib test && node ../scripts/run-dart.js analyze",
    "test:dart": "cd dart_cli && node ../scripts/run-dart.js test",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "commitizen": "^4.3.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3"
  },
  "packageManager": "yarn@4.13.0"
}
